.idea/
*.sln.DotSettings.user

# ── VSCode ────────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json

# ── Secrets / env ────────────────────────────────────────────────────────────
.env
*.env.local
secrets.json
